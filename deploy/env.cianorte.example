# ══════════════════════════════════════════════════════
#  37 Sushi — Unidade CIANORTE
#  Copie para: /opt/37sushi/cianorte/.env
# ══════════════════════════════════════════════════════

# ── Identidade da unidade ──────────────────────────────
UNIDADE=cianorte
NOME_RESTAURANTE=37 Sushi Cianorte
PORT=3002
NODE_ENV=production

# ── Banco de dados ─────────────────────────────────────
DB_PATH=/opt/37sushi/cianorte/data/sushi.db

# ── URLs ───────────────────────────────────────────────
APP_URL=https://cianorte.37sushi.com.br
FRONTEND_URL=https://cianorte.37sushi.com.br

# ── Segurança ──────────────────────────────────────────
# DIFERENTE do de Paranavaí — cada unidade tem o seu!
JWT_SECRET=GERE_UM_SEGREDO_DIFERENTE_AQUI

# ── IA (Claude) ────────────────────────────────────────
ANTHROPIC_API_KEY=SUA_CHAVE_ANTHROPIC_AQUI

# ── WhatsApp ───────────────────────────────────────────
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=/opt/37sushi/cianorte/data/whatsapp-session
