# ══════════════════════════════════════════════════════
#  37 Sushi — Unidade PARANAVAÍ
#  Copie para: /opt/37sushi/paranavaí/.env
# ══════════════════════════════════════════════════════

# ── Identidade da unidade ──────────────────────────────
UNIDADE=paranavaí
NOME_RESTAURANTE=37 Sushi Paranavaí
PORT=3001
NODE_ENV=production

# ── Banco de dados ─────────────────────────────────────
# Caminho absoluto no servidor
DB_PATH=/opt/37sushi/paranavaí/data/sushi.db

# ── URLs ───────────────────────────────────────────────
APP_URL=https://paranavaí.37sushi.com.br
FRONTEND_URL=https://paranavaí.37sushi.com.br

# ── Segurança ──────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_SEGREDO_AQUI

# ── IA (Claude) ────────────────────────────────────────
ANTHROPIC_API_KEY=SUA_CHAVE_ANTHROPIC_AQUI

# ── WhatsApp ───────────────────────────────────────────
WHATSAPP_ENABLED=true
# Pasta da sessão WhatsApp (isolada por unidade)
WHATSAPP_SESSION_PATH=/opt/37sushi/paranavaí/data/whatsapp-session
